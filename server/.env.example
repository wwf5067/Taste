# 发布后端配置（复制为 .env 并填好；.env 不要提交到仓库）

# 作者登录口令（必填，设一个不易猜的强口令）
PUBLISH_PASSWORD=change-me-please

# 签发 session cookie 用的密钥（必填，随机长字符串）
SESSION_SECRET=replace-with-a-long-random-string

# 站点源码仓库目录（含 docs/，后端在此就地构建）
REPO_DIR=/opt/taste/repo

# 构建产物同步到的 nginx 目录（与 nginx 容器共享挂载）
WEB_DIST=/opt/taste/web-dist

# 允许的板块（逗号分隔，对应 docs 下目录名）
SECTIONS=health,perfume,photography,emotion

# 后端监听端口
PORT=8092

# session 有效期（小时）
SESSION_HOURS=12

# 单张图片大小上限（MB）
MAX_IMAGE_MB=8
